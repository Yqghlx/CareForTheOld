# CareForTheOld 环境变量配置
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# 注意：.env 文件不应提交到版本控制

# ===== Docker Compose 必须配置 =====

# PostgreSQL 数据库
POSTGRES_USER=carefortheold
POSTGRES_PASSWORD=          # 必填：openssl rand -base64 24
POSTGRES_DB=carefortheold
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API 服务
API_PORT=5001
ASPNETCORE_ENVIRONMENT=Production

# JWT 密钥（至少 32 个字符，生产环境必须配置）
# 生成方式：openssl rand -base64 48
# 开发环境自动使用默认密钥，无需配置
JWT_SECRET_KEY=             # 生产环境必填

# ===== 应用配置 =====

# 数据库连接字符串（Docker Compose 自动拼接，独立运行时需配置）
ConnectionStrings__DefaultConnection=Host=;Port=5432;Database=carefortheold;Username=;Password=;Pooling=true;Minimum Pool Size=10;Maximum Pool Size=200;Connection Lifetime=300;

# Redis 连接（留空则使用内存缓存）
ConnectionStrings__Redis=

# CORS 允许的前端域名（多个用分号分隔）
Cors__AllowedOrigins=https://your-domain.com

# ===== 前端编译配置 =====

# Sentry DSN（留空则禁用错误监控）
# SENTRY_DSN=

# 应用环境（development/production）
# APP_ENV=production
