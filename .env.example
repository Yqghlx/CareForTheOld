# CareForTheOld 环境变量配置
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# 注意：.env 文件不应提交到版本控制

# ===== Docker Compose 必须配置 =====

# PostgreSQL 数据库密码（必填！）
# 生成安全密码：openssl rand -base64 24
# 示例（请勿直接使用）：kT8xQ2mNpL9vR3hJ7wY4cX6bZ1
POSTGRES_PASSWORD=             # ⚠️ 必填：生产环境启动前必须设置
POSTGRES_DB=carefortheold
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API 服务
API_PORT=5001
ASPNETCORE_ENVIRONMENT=Production

# JWT 签名密钥（生产环境必填！至少 32 个字符）
# 生成安全密钥：openssl rand -base64 48
# 示例（请勿直接使用）：Yq7kT2mNpL9vR3hJ7wY4cX6bZ1aE8fD5gS0iU3oP6nM2
# ⚠️ 开发环境自动使用默认密钥，生产环境启动前必须设置，否则拒绝启动
JWT_SECRET_KEY=             # ⚠️ 生产环境必填

# ===== 应用配置 =====

# 数据库连接字符串（Docker Compose 自动拼接，独立运行时需配置）
ConnectionStrings__DefaultConnection=Host=;Port=5432;Database=carefortheold;Username=;Password=;Pooling=true;Minimum Pool Size=10;Maximum Pool Size=200;Connection Lifetime=300;

# Redis 连接（留空则使用内存缓存）
ConnectionStrings__Redis=

# CORS 允许的前端域名（多个用分号分隔）
# ⚠️ 生产环境必填：未配置时将拒绝所有跨域请求，导致前端无法访问 API
# 示例：Cors__AllowedOrigins=https://your-domain.com;https://app.your-domain.com
Cors__AllowedOrigins=

# ===== OSS 文件存储配置 =====

# 是否启用 OSS（true/false，默认 false 使用本地存储）
OSS_ENABLED=false

# 阿里云 OSS Endpoint（如：https://oss-cn-hangzhou.aliyuncs.com）
OSS_ENDPOINT=

# OSS AccessKey ID
OSS_ACCESS_KEY_ID=

# OSS AccessKey Secret
OSS_ACCESS_KEY_SECRET=

# OSS Bucket 名称
OSS_BUCKET_NAME=

# ===== SMS 短信服务配置 =====

# 短信服务商（aliyun 国内 / twilio 国际）
Sms__Provider=aliyun

# 阿里云短信配置
Sms__Aliyun__AccessKeyId=
Sms__Aliyun__AccessKeySecret=
Sms__Aliyun__SignName=         # 短信签名名称（需在阿里云审核通过）
Sms__Aliyun__TemplateCode=     # 短信模板 CODE（需在阿里云审核通过）

# Twilio 短信配置（国际用户）
Sms__Twilio__AccountSid=
Sms__Twilio__AuthToken=
Sms__Twilio__FromNumber=       # Twilio 发送号码（如 +1234567890）

# ===== 前端编译配置 =====

# Sentry DSN（留空则禁用错误监控）
# SENTRY_DSN=

# 应用环境（development/production）
# APP_ENV=production
