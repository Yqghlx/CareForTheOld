# CareForTheOld 生产环境变量配置
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# 注意：.env 文件不应提交到版本控制

# ===== 必须配置 =====

# JWT 密钥（至少 32 个字符，建议使用随机生成的强密钥）
# 生成方式：openssl rand -base64 48
JWT_SECRET_KEY=

# 数据库连接字符串（PostgreSQL，含连接池配置）
ConnectionStrings__DefaultConnection=Host=;Port=5432;Database=carefortheold;Username=;Password=;Pooling=true;Minimum Pool Size=10;Maximum Pool Size=200;Connection Lifetime=300;

# Redis 连接（留空则使用内存缓存）
ConnectionStrings__Redis=

# CORS 允许的前端域名（多个用分号分隔）
Cors__AllowedOrigins=https://your-domain.com

# ===== 可选配置 =====

# API 端口
ASPNETCORE_URLS=http://+:5000

# 环境
ASPNETCORE_ENVIRONMENT=Production
