{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Hangfire": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/carefortheold-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] [Thread:{ThreadId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "CareForTheOld",
    "Audience": "CareForTheOld",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimit": {
    "AuthPermitLimit": 5,
    "AuthWindow": 60,
    "GeneralPermitLimit": 60,
    "GeneralWindow": 60,
    "JoinFamilyPermitLimit": 3,
    "JoinFamilyWindow": 300,
    "JoinCirclePermitLimit": 5,
    "JoinCircleWindow": 300,
    "EmergencyPermitLimit": 2,
    "EmergencyWindow": 60,
    "HealthPermitLimit": 60,
    "HealthWindow": 60
  },
  "Heartbeat": {
    "TimeoutMinutes": 5,
    "AlertCooldownMinutes": 15
  },
  "MedicationReminder": {
    "AdvanceMinutes": 5
  },
  "Location": {
    "AccuracyThresholdMeters": 100
  },
  "Emergency": {
    "FollowUpDelayMinutes": 3
  },
  "TrustScore": {
    "Enabled": true
  },
  "AutoRescue": {
    "Enabled": true,
    "DelayMinutes": 5
  },
  "AllowedHosts": "*"
}
