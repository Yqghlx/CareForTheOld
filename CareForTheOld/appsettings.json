{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=carefortheold.db"
  },
  "Jwt": {
    "Key": "",
    "Issuer": "CareForTheOld",
    "Audience": "CareForTheOld",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimit": {
    "AuthPermitLimit": 10,
    "AuthWindow": 60,
    "GeneralPermitLimit": 60,
    "GeneralWindow": 60
  },
  "Heartbeat": {
    "TimeoutMinutes": 5,
    "AlertCooldownMinutes": 15
  },
  "MedicationReminder": {
    "AdvanceMinutes": 5
  },
  "Location": {
    "AccuracyThresholdMeters": 100
  },
  "Emergency": {
    "FollowUpDelayMinutes": 3
  },
  "TrustScore": {
    "Enabled": true
  },
  "AutoRescue": {
    "Enabled": true,
    "DelayMinutes": 5
  },
  "AllowedHosts": "*"
}